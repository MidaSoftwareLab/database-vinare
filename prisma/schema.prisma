// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

//region Enums

enum QrCodeStatus {
  active
  disabled
}

enum Permission {
  dashboard
  qrcode
  billings
  chatbot
  agents
}

enum AgentKind {
  ecommerce
}

enum LauncherStyle {
  BUBBLE
  PILL
  BADGE_AVATAR
}

enum LauncherPosition {
  BOTTOM_RIGHT
  BOTTOM_LEFT
  BOTTOM_CENTER
}

//region WebApp
model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  members     Member[]
  invitations Invitation[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id        String   @id
  name      String
  slug      String?
  logo      String?
  createdAt DateTime
  metadata  String?

  // Stripe
  stripeCustomerId        String?   @unique
  stripeSubscriptionId    String?   @unique
  stripeStatus            String?
  stripeCurrentPeriodEnd  DateTime?
  stripePriceId           String?
  stripeCancelAtPeriodEnd Boolean   @default(false)

  members     Member[]
  invitations Invitation[]

  billingProfile BillingProfile?

  // Qr
  qrCodes  QrCode[]
  chatbots Chatbot[]

  // Agents
  agents             Agent[]
  agentConversations AgentConversation[]

  // Personae Analytics
  dashboardConfig OrgConfigurationsDashboard?
  feedbackRecords FeedbackRecord[]

  @@unique([slug])
  @@map("organization")
}

model BillingProfile {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  companyName String
  taxId       String // P.IVA, VIES, EIN
  fiscalCode  String? // Codice Fiscale (Italia)
  sdiCode     String? // Codice Destinatario (Italia - 7 caratteri)
  pecAddress  String? // Indirizzo PEC (Italia)

  address    String?
  city       String?
  state      String? // Provincia o Regione
  postalCode String? // CAP o ZIP Code
  country    String  @default("IT")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("billing_profile")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  permissions    Permission[] @default([])
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  permissions    Permission[] @default([])
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model QrCode {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  publicCode    String    @unique
  scanCount     Int       @default(0)
  lastScannedAt DateTime?

  status QrCodeStatus @default(active)

  chatbotId String?
  chatbot   Chatbot? @relation(fields: [chatbotId], references: [id], onDelete: SetNull)

  designConfig Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scans QrScan[]

  @@index([organizationId])
  @@map("qr_code")
}

model QrScan {
  id       String @id @default(cuid())
  qrCodeId String
  qrCode   QrCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  userAgent String?
  browser   String?
  os        String?
  device    String?
  country   String?
  city      String?
  region    String?
  language  String?
  referer   String?

  createdAt DateTime @default(now())

  @@index([qrCodeId])
  @@map("qr_scan")
}

model Chatbot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  systemPrompt String  @default("Sei l'assistente virtuale...")
  language     String  @default("it")

  useStreaming Boolean @default(false)
  enableAudio  Boolean @default(false)

  publicCode    String    @unique
  scanCount     Int       @default(0)
  lastScannedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qrCodes QrCode[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("chatbot")
}

model Agent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  systemPrompt String  @default("")
  language     String  @default("it")
  publicCode   String  @unique
  kind         AgentKind @default(ecommerce)

  // Commerce Configuration
  providerType   String // "shopify" | "woocommerce" | "magento"
  storeUrl       String // "https://myshop.myshopify.com"
  storeName      String?
  storeCurrency  String   @default("EUR")
  storePolicy    String? // Policy text (returns, shipping) for system prompt enrichment
  encryptedCreds String // JSON encrypted with AES-256-GCM
  allowedDomains String[] // Authorized domains for CORS + embed

  // Feature flags
  ecommerceEnabled Boolean @default(true)

  // Appearance — basic
  logoUrl      String?
  primaryColor String?

  // Appearance — personality (Phase 2)
  botName        String?
  avatarEmoji    String?  @default("🍷")
  avatarUrl      String?

  // Appearance — conversation (Phase 2)
  welcomeMessage    String?
  suggestionChips   Json?   // array of { label: string, payload?: string } — max 5

  // Appearance — launcher (Phase 2)
  launcherStyle    LauncherStyle    @default(BUBBLE)
  launcherPosition LauncherPosition @default(BOTTOM_RIGHT)
  launcherOffsetX  Int              @default(20)
  launcherOffsetY  Int              @default(20)

  // Conversion (Phase 3)
  teaserEnabled     Boolean  @default(false)
  teaserDelaySec    Int      @default(15)
  teaserText        String?
  onboardingEnabled Boolean  @default(false)

  // Stats
  scanCount     Int       @default(0)
  lastScannedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, kind])
  @@index([organizationId])
  @@map("agent")
}

//region Azure Services

// ============================================================================
// SOMMELIER-VIRTUALE TABLES (EXTERNAL PYTHON BACKEND)
// Coexist alongside Prisma tables but were historically managed by SQL.
// Mapped here to allow querying from the Next.js app.
// ============================================================================

model WineLinePrompt {
  wineLineId String @map("wine_line_id")
  lang       String
  promptText String @map("prompt_text")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([wineLineId, lang])
  @@map("wine_line_prompt")
}

model ChatConversation {
  id             String  @id
  publicId       String  @unique @map("public_id")
  organizationId String  @map("organization_id")
  wineLineId     String  @map("wine_line_id")
  parentId       String? @map("parent_id")

  parent   ChatConversation?  @relation("ParentChild", fields: [parentId], references: [id])
  children ChatConversation[] @relation("ParentChild")

  status         String  @default("active")
  source         String  @default("real") // Pulled from Python DB, needed for Personae
  sentimentScore Int?    @map("sentiment_score") // Pulled from Python DB, needed for Personae
  userLang       String? @map("user_lang")
  title          String?
  metadata       Json?
  nextSeq        Int     @default(1) @map("next_seq")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  messages  ChatMessage[]
  embedding ConversationEmbedding?
  analytics ConversationAnalytics?

  @@index([publicId], map: "idx_chat_conversation_public_id")
  @@index([organizationId], map: "idx_chat_conversation_org_id")
  @@index([wineLineId], map: "idx_chat_conversation_wl_id")
  @@map("chat_conversation")
}

model ChatMessage {
  id             String @id
  conversationId String @map("conversation_id")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  seq              Int
  role             String
  content          String
  model            String?
  temperature      Float?
  maxTokens        Int?    @map("max_tokens")
  promptTokens     Int?    @map("prompt_tokens")
  completionTokens Int?    @map("completion_tokens")
  totalTokens      Int?    @map("total_tokens")
  latencyMs        Int?    @map("latency_ms")
  metadata         Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([conversationId, seq])
  @@index([conversationId], map: "idx_chat_message_conversation_id")
  @@map("chat_message")
}

// ============================================================================
// PERSONAE ANALYTICS & EMBEDDINGS (NEW)
// ============================================================================

model ConversationEmbedding {
  id             String                      @id
  conversationId String                      @unique @map("conversation_id")
  embedding      Unsupported("vector(1536)")
  createdAt      DateTime                    @default(now()) @map("created_at")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("conversation_embedding")
}

model ConversationAnalytics {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String  @unique @map("conversation_id")
  personaName    String? @map("persona_name")
  primaryIntent  String? @map("primary_intent")
  technicality   Float?
  buyingIntent   Float?  @map("buying_intent")
  tone           Float?
  tempo          Float?
  occasionLogic  Float?  @map("occasion_logic")
  clusterId      Int?    @map("cluster_id")
  pcaX           Float?  @map("pca_x")
  pcaY           Float?  @map("pca_y")
  timelineData   Json?   @map("timeline_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("conversation_analytics")
}

// ============================================================================
// PERSONAE ANALYTICS & EMBEDDINGS (NEW - UNIFIED FEEDBACK)
// ============================================================================

model OrgConfigurationsDashboard {
  organizationId       String       @id @map("organization_id")
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dimensionsBlobUri    String?      @map("dimensions_blob_uri")
  scraperConfigBlobUri String?      @map("scraper_config_blob_uri")
  baselinesBlobUri     String?      @map("baselines_blob_uri")
  nClusters            Int          @default(6) @map("n_clusters")
  lastExtractionAt     DateTime?    @map("last_extraction_at")
  lastEvaluationAt     DateTime?    @map("last_evaluation_at")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @default(now()) @updatedAt @map("updated_at")

  @@map("org_configurations_dashboard")
}

model FeedbackRecord {
  id              String       @id
  organizationId  String       @map("organization_id")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source          String
  sourceId        String       @map("source_id")
  content         String
  rating          Float?
  metadata        Json?
  language        String       @default("en")
  contentHash     String?      @map("content_hash")
  sourceCreatedAt DateTime?    @map("source_created_at")
  ingestedAt      DateTime     @default(now()) @map("ingested_at")

  clusterId     Int?      @map("cluster_id")
  personaName   String?   @map("persona_name")
  pcaX          Float?    @map("pca_x")
  pcaY          Float?    @map("pca_y")
  primaryIntent String?   @map("primary_intent")
  technicality  Float?
  buyingIntent  Float?    @map("buying_intent")
  palateProfile Float?    @map("palate_profile")
  occasionLogic Float?    @map("occasion_logic")
  evaluatedAt   DateTime? @map("evaluated_at")

  embedding       FeedbackEmbedding?
  mlProfile       FeedbackMlProfile?
  dimensionScores FeedbackDimensionScore[]

  @@unique([organizationId, source, sourceId])
  @@index([organizationId], map: "idx_feedback_record_org_id")
  @@index([organizationId, source], map: "idx_feedback_record_org_source")
  @@index([organizationId, contentHash], map: "idx_feedback_record_org_content_hash")
  // For picking up stale evaluations
  @@map("feedback_record")
}

model FeedbackEmbedding {
  id               String                       @id
  feedbackRecordId String                       @unique @map("feedback_record_id")
  feedbackRecord   FeedbackRecord               @relation(fields: [feedbackRecordId], references: [id], onDelete: Cascade)
  embedding        Unsupported("vector(3072)")?
  createdAt        DateTime                     @default(now()) @map("created_at")

  @@map("feedback_embedding")
}

model FeedbackMlProfile {
  id               String         @id
  feedbackRecordId String         @unique @map("feedback_record_id")
  feedbackRecord   FeedbackRecord @relation(fields: [feedbackRecordId], references: [id], onDelete: Cascade)

  clusterId     Int?    @map("cluster_id")
  personaName   String? @map("persona_name")
  primaryIntent String? @map("primary_intent")

  segmentationStatus String  @map("segmentation_status")
  segmentationScope  String  @map("segmentation_scope")
  exclusionReason    String? @map("exclusion_reason")

  namingRationale    String? @map("naming_rationale")
  namingConfidence   Float?  @map("naming_confidence")
  dominantDimensions Json?   @map("dominant_dimensions")
  dominantPoles      Json?   @map("dominant_poles")

  pcaX Float? @map("pca_x")
  pcaY Float? @map("pca_y")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([personaName], map: "idx_feedback_ml_profile_persona")
  @@index([segmentationStatus], map: "idx_feedback_ml_profile_seg_status")
  @@map("feedback_ml_profile")
}

model FeedbackDimensionScore {
  id               String         @id
  feedbackRecordId String         @map("feedback_record_id")
  feedbackRecord   FeedbackRecord @relation(fields: [feedbackRecordId], references: [id], onDelete: Cascade)

  dimensionId   Int    @map("dimension_id")
  dimensionKey  String @map("dimension_key")
  dimensionName String @map("dimension_name")

  rawScore        Float?  @map("raw_score")
  normalizedScore Float?  @map("normalized_score")
  pole1           String  @map("pole_1")
  pole2           String  @map("pole_2")
  dominantPole    String? @map("dominant_pole")
  isNeutral       Boolean @default(false) @map("is_neutral")
  ciLow           Float?  @map("ci_low")
  ciHigh          Float?  @map("ci_high")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([feedbackRecordId, dimensionKey])
  @@index([dimensionKey], map: "idx_feedback_dimension_score_dim_key")
  @@index([feedbackRecordId], map: "idx_feedback_dimension_score_record_id")
  @@map("feedback_dimension_score")
}

//region E-commerce Agent

model AgentConversation {
  id             String       @id
  publicId       String       @unique @map("public_id")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  agentId      String @map("agent_id") @db.VarChar(128)
  providerType String @map("provider_type") @db.VarChar(32)
  mode         String @default("embedded") @db.VarChar(16)
  userLang     String @default("en") @map("user_lang") @db.VarChar(8)
  status       String @default("active") @db.VarChar(16)

  cartId       String? @map("cart_id")
  cartMetadata Json    @default("{}") @map("cart_metadata")
  metadata     Json    @default("{}")
  nextSeq      Int     @default(0) @map("next_seq")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  messages AgentMessage[]

  @@index([organizationId])
  @@index([agentId])
  @@map("agent_conversation")
}

model AgentMessage {
  id             String            @id
  conversationId String            @map("conversation_id")
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  seq     Int
  role    String @db.VarChar(16)
  content String

  toolCallId String? @map("tool_call_id")
  toolName   String? @map("tool_name") @db.VarChar(128)

  model            String? @db.VarChar(128)
  temperature      Float?  @db.Real
  maxTokens        Int?    @map("max_tokens")
  promptTokens     Int?    @map("prompt_tokens")
  completionTokens Int?    @map("completion_tokens")
  totalTokens      Int?    @map("total_tokens")
  latencyMs        Int?    @map("latency_ms")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([conversationId, seq])
  @@index([conversationId, seq])
  @@map("agent_message")
}
