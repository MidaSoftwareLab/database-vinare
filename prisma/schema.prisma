// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum QrCodeStatus {
  active
  disabled
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  members     Member[]
  invitations Invitation[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id        String   @id
  name      String
  slug      String?
  logo      String?
  createdAt DateTime
  metadata  String?

  // Stripe
  stripeCustomerId        String?   @unique
  stripeSubscriptionId    String?   @unique
  stripeStatus            String?
  stripeCurrentPeriodEnd  DateTime?
  stripePriceId           String?
  stripeCancelAtPeriodEnd Boolean   @default(false)

  members     Member[]
  invitations Invitation[]

  // Qr
  qrCodes  QrCode[]
  chatbots Chatbot[]

  @@unique([slug])
  @@map("organization")
}

enum Permission {
  dashboard
  qrcode
  billings
  chatbot
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  permissions    Permission[] @default([])
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  permissions    Permission[] @default([])
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model QrCode {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  publicCode    String    @unique
  scanCount     Int       @default(0)
  lastScannedAt DateTime?

  status QrCodeStatus @default(active)

  chatbotId String?
  chatbot   Chatbot? @relation(fields: [chatbotId], references: [id], onDelete: SetNull)

  designConfig Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scans QrScan[]

  @@index([organizationId])
  @@map("qr_code")
}

model Chatbot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  systemPrompt String  @default("Sei l'assistente virtuale...")
  language     String  @default("it")

  useStreaming Boolean @default(false)
  enableAudio  Boolean @default(false)

  publicCode    String    @unique
  scanCount     Int       @default(0)
  lastScannedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qrCodes QrCode[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("chatbot")
}

// ============================================================================
// SOMMELIER-VIRTUALE TABLES (EXTERNAL PYTHON BACKEND)
// Coexist alongside Prisma tables but were historically managed by SQL.
// Mapped here to allow querying from the Next.js app.
// ============================================================================

model WineLinePrompt {
  wineLineId String @map("wine_line_id")
  lang       String
  promptText String @map("prompt_text")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([wineLineId, lang])
  @@map("wine_line_prompt")
}

model ChatConversation {
  id             String  @id
  publicId       String  @unique @map("public_id")
  organizationId String  @map("organization_id")
  wineLineId     String  @map("wine_line_id")
  parentId       String? @map("parent_id")

  parent   ChatConversation?  @relation("ParentChild", fields: [parentId], references: [id])
  children ChatConversation[] @relation("ParentChild")

  status         String  @default("active")
  source         String  @default("real")            // Pulled from Python DB, needed for Personae
  sentimentScore Int?    @map("sentiment_score")     // Pulled from Python DB, needed for Personae
  userLang       String? @map("user_lang")
  title          String?
  metadata       Json?
  nextSeq        Int     @default(1) @map("next_seq")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  messages  ChatMessage[]
  embedding ConversationEmbedding?
  analytics ConversationAnalytics?

  @@index([publicId], map: "idx_chat_conversation_public_id")
  @@index([organizationId], map: "idx_chat_conversation_org_id")
  @@index([wineLineId], map: "idx_chat_conversation_wl_id")
  @@map("chat_conversation")
}

model ChatMessage {
  id             String @id
  conversationId String @map("conversation_id")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  seq              Int
  role             String
  content          String
  model            String?
  temperature      Float?
  maxTokens        Int?    @map("max_tokens")
  promptTokens     Int?    @map("prompt_tokens")
  completionTokens Int?    @map("completion_tokens")
  totalTokens      Int?    @map("total_tokens")
  latencyMs        Int?    @map("latency_ms")
  metadata         Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([conversationId, seq])
  @@index([conversationId], map: "idx_chat_message_conversation_id")
  @@map("chat_message")
}

model QrScan {
  id       String @id @default(cuid())
  qrCodeId String
  qrCode   QrCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  userAgent String?
  browser   String?
  os        String?
  device    String?
  country   String?
  city      String?

  createdAt DateTime @default(now())

  @@index([qrCodeId])
  @@map("qr_scan")
}

// ============================================================================
// PERSONAE ANALYTICS & EMBEDDINGS (NEW)
// ============================================================================

model ConversationEmbedding {
  id             String           @id
  conversationId String           @unique @map("conversation_id")
  embedding      Unsupported("vector(1536)")
  createdAt      DateTime         @default(now()) @map("created_at")

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("conversation_embedding")
}

model ConversationAnalytics {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String           @unique @map("conversation_id")
  personaName    String?          @map("persona_name")
  primaryIntent  String?          @map("primary_intent")
  technicality   Float?
  buyingIntent   Float?           @map("buying_intent")
  tone           Float?
  tempo          Float?
  occasionLogic  Float?           @map("occasion_logic")
  clusterId      Int?             @map("cluster_id")
  pcaX           Float?           @map("pca_x")
  pcaY           Float?           @map("pca_y")
  timelineData   Json?            @map("timeline_data")
  
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("conversation_analytics")
}
